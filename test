    cleanup = function()
        for i = #_G._NEXTHUB.conns, 1, -1 do
            local c = _G._NEXTHUB.conns[i]
            pcall(function() 
                if c and c.Connected then 
                    c:Disconnect() 
                end 
            end)
        end

        for i = #_G._NEXTHUB.tasks, 1, -1 do
            local t = _G._NEXTHUB.tasks[i]
            pcall(function() 
                if t then 
                    task.cancel(t) 
                end 
            end)
        end

        for i = #_G._NEXTHUB.instances, 1, -1 do
            local inst = _G._NEXTHUB.instances[i]
            pcall(function() 
                if inst and inst.Parent then 
                    inst:Destroy() 
                end 
            end)
        end

        _G._NEXTHUB.conns = {}
        _G._NEXTHUB.tasks = {}
        _G._NEXTHUB.instances = {}
        _G._NEXTHUB = nil

        rawset(getgenv(), "NEXTHUB_MAIN_RUNNING", nil)
    end
}

