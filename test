-- =====================================================================
-- TAB: WEBHOOK
-- =====================================================================
do
    if IsPremium and WebhookModule then
        local Webhook = Tabs.Webhook

        Webhook:AddSection({ Title = "Webhook" })

        local webHookUrl = ""

        Webhook:AddDropdown("WebhookTiers", {
            Title = "Tiers", 
            Options = WebhookModule.GetAllowedTiers(),
            Default = nil, 
            Multi = true,
            Callback = function(v) WebhookModule.SetTierFilter(v) end
        })

        Webhook:AddInput("WebhookURL", {
            Title = "Webhook URL", 
            Default = nil,
            Callback = function(v)
                webHookUrl = tostring(v)
                WebhookModule.SetWebhookURL(v)
            end
        })

        Webhook:AddToggle("WebhookEnabled", {
            Title = "Webhook", 
            Default = false,
            Callback = function(v)
                if v then
                    if not webHookUrl or not webHookUrl:match("discord%.com/api/webhooks") then
                        Notifier("Error", "Invalid webhook URL", 5)
                        return
                    end
                    WebhookModule.Start()
                else
                    WebhookModule.Stop()
                end
            end
        })

        Webhook:AddButton({
            Title = "Test Webhook",
            Callback = function()
                if not webHookUrl or not webHookUrl:match("discord%.com/api/webhooks") then
                    Notifier("Error", "Invalid webhook URL", 5)
                    return
                end
                WebhookModule.TestWebhook()
                Notifier("Success", "Test webhook sent", 5)
            end
        })
    end
end

