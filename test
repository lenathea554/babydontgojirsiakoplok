            "Update Available", 
            "New version: v" .. versionResult.version .. changelogText, 
            3600
        )
    end
end

local watcher = task.spawn(function()
    while task.wait(CHECK_INTERVAL) do
        local r = SecurityCore.CheckVersion(SCRIPT_VERSION)
        if r == false then 
            break 
        end

        if type(r) == "table" and r.type == "update" then
            if not _G._NEXTHUB.updateShown then
                _G._NEXTHUB.updateShown = true
                Notifier("Update Available", "New version: v" .. r.version, 3600)
            end
        end
    end
