function UI:setStep(pct, text)
    self.TARGET = pct
    if text and self.status then self.status.Text = text end
end

local function waitUntilBarReached()
    while UI.CURRENT < UI.TARGET do
        task.wait(0.1)
    end
end

function UI:runStep(target, text, fn, minTime)
    self:setStep(target, text)
    
    waitUntilBarReached()

    minTime = (minTime or 0.25) + math.random() * 0.15

    local t0 = os.clock()
    local ok, err = pcall(fn)
    local dt = os.clock() - t0

    if not ok then end

    if dt < minTime then task.wait(minTime - dt) end
    return ok
end

function UI:Finish()
    self:setStep(100, "Ready!")
    task.wait(0.5)
    if self.blur then
        service.TweenService:Create(self.blur, TweenInfo.new(0.25), {Size = 0}):Play()
    end
    self.RUNNING = false
    task.wait(0.25)
    if self.gui then self.gui:Destroy() end
    if self.blur then self.blur:Destroy() end
end

